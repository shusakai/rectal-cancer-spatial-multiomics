# Data files (large; managed separately)
data/
*.h5ad
*.loom
*.h5

# Intermediate results and figures (regenerated by notebooks)
results/
figures/

# Jupyter notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Conda/pip environments
.venv/
venv/
env/
*.egg-info/
dist/
build/

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.log
tmp/

# Large output files
*.png
*.pdf
*.svg
*.eps

# Sensitive data
*.key
*.pem
secrets.txt

# Track directory structure
!data/.gitkeep
!figures/.gitkeep
!results/.gitkeep
